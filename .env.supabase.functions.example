# Copy this file to `.env.supabase.functions` and fill in the values.
# Never commit `.env.supabase.functions` (it is gitignored).
#
# Push to Supabase Edge Function secrets:
#   npx supabase login
#   npm run secrets:push
#
# Values come from Stripe Dashboard (Developers → API keys, Product catalog, Webhooks).

STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_PAID=
STRIPE_WEBHOOK_SECRET=

# Optional: production site URL (no trailing slash). Omit for local-only testing.
# SITE_URL=
