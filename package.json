{
  "name": "innocence-found",
  "version": "1.0.0",
  "description": "*A storytelling and educational platform created for author Cynthia Davies.*",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "secrets:push": "npx --yes supabase@latest secrets set --env-file .env.supabase.functions --project-ref khiwkbnqjjycmwonbhqu",
    "secrets:list": "npx --yes supabase@latest secrets list --project-ref khiwkbnqjjycmwonbhqu",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watchman=false",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watchman=false --coverage --coverageReporters=lcov --coverageReporters=text --coverageDirectory=coverage --watchAll=false",
    "test:serial": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmcglasson/Innocence-Found.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dmcglasson/Innocence-Found/issues"
  },
  "homepage": "https://github.com/dmcglasson/Innocence-Found#readme",
  "directories": {
    "test": "tests"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  }
}
